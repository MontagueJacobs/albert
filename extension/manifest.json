{
  "manifest_version": 3,
  "name": "Sustainable Shop - AH Sync",
  "version": "1.1.0",
  "description": "Sync your Albert Heijn purchase history to track sustainability scores",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.ah.nl/*",
    "https://albert-rm0mq7c61-montaguejacobs-projects.vercel.app/*",
    "http://localhost:3001/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.ah.nl/producten/eerder-gekocht*",
        "https://www.ah.nl/mijn/eerder-gekocht*",
        "https://www.ah.nl/bonus/eerder-gekocht*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
