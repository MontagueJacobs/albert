# Backend configuration
PORT=3001
PYTHON=python3

# Catalog source (Supabase)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
# Use the service role key for seeding and server-side catalog refreshes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Unified products table (replaces old product_catalog and ah_products)
SUPABASE_PRODUCTS_TABLE=products
SUPABASE_SCHEMA=public
CATALOG_REFRESH_INTERVAL_MS=900000

# User authentication & data encryption
# Used to encrypt AH cookies stored in database
COOKIES_ENCRYPTION_KEY=your-32-char-encryption-key-here

# USDA FoodData Central API (for ingredient nutrition profiles)
# Get a free key at https://api.data.gov/signup/
USDA_API_KEY=your-usda-api-key-here

# Auto-scraping (optional)
# For Vercel/serverless: use Browserless.io or similar remote browser service
# Get a token at https://www.browserless.io/ and set the URL below
# BROWSERLESS_URL=wss://chrome.browserless.io?token=YOUR_TOKEN
